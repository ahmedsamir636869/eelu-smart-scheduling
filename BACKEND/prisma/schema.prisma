generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          String      @id @default(cuid())
  name                        String
  email                       String      @unique
  password                    String
  roles                       UserRole[]  @default([INSTRUCTOR])
  isExpatriate                Boolean?    
  createdAt                   DateTime    @default(now())
  updatedAt                   DateTime    @updatedAt
  emailVerified               Boolean     @default(false)
  resetPasswordToken          String?     @unique
  resetPasswordTokenExpires   DateTime?
  resetPasswordOtp            String?
  resetPasswordOtpExpires     DateTime?
  emailVerificationOtp        String?
  emailVerificationOtpExpires DateTime?
  sessions                    Session[]
  instructor                  Instructor?
  ta                          TA?
}

model Campus {
  id         String      @id @default(cuid())
  name       String      @unique
  city       String
  classrooms Classroom[]
  colleges   College[]   @relation("CampusColleges")
  schedules Schedule[]
}

model College {
  id          String       @id @default(cuid())
  name        String
  campusId    String?
  campus      Campus?      @relation("CampusColleges", fields: [campusId], references: [id])
  courses     Course[]
  departments Department[]
}

model Department {
  id            String         @id @default(cuid())
  name          String
  collegeId     String
  code          String
  courses       Course[]
  college       College        @relation(fields: [collegeId], references: [id])
  instructors   Instructor[]
  tas           TA[]
  studentGroups StudentGroup[]
}

model Course {
  id           String       @id @default(cuid())
  code         String       @unique
  departmentId String
  name         String
  type         CourseType
  collegeId    String
  days         Int
  hoursPerDay  Int
  instructorId String?
  taId         String?
  year         Int
  college      College      @relation(fields: [collegeId], references: [id])
  department   Department   @relation(fields: [departmentId], references: [id])
  instructor   Instructor?  @relation("AssignedInstructor", fields: [instructorId], references: [id])
  ta           TA?          @relation("AssignedTA", fields: [taId], references: [id])
  sessions     Session[]
  instructors  Instructor[] @relation("AdditionalInstructors")
}

model Instructor {
  id              String          @id @default(cuid())
  name            String
  email           String          @unique
  userId          String?         @unique
  departmentId    String
  employmentType  EmploymentType  @default(FULL_TIME)
  assignedCourses Course[]        @relation("AssignedInstructor")
  department      Department      @relation(fields: [departmentId], references: [id])
  otherCourses    Course[]        @relation("AdditionalInstructors")
  user            User?           @relation(fields: [userId], references: [id])
  availability    InstructorAvailability[]
}

model InstructorAvailability {
  id              String             @id @default(cuid())
  instructorId    String
  day             DayOfWeek
  startTime       DateTime
  endTime         DateTime
  status          AvailabilityStatus @default(PENDING)
  instructor      Instructor         @relation(fields: [instructorId], references: [id])

  @@unique([instructorId, day])
}

model TA {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  userId       String?      @unique
  departmentId String
  isExpatriate Boolean      @default(false)
  department   Department   @relation(fields: [departmentId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])
  courses      Course[]     @relation("AssignedTA")
  reports      TAReport[]
  offDays      TAOffDay[]
}

model TAOffDay {
  id    String    @id @default(cuid())
  taId  String
  day   DayOfWeek
  ta    TA        @relation(fields: [taId], references: [id])

  @@unique([taId, day])
}

model TAReport {
  id        String         @id @default(cuid())
  taId      String
  title     String
  content   String
  status    ReportStatus   @default(UNREAD)
  createdAt DateTime       @default(now())
  ta        TA             @relation(fields: [taId], references: [id])
}

model StudentGroup {
  id           String     @id @default(cuid())
  name         String
  departmentId String
  year         Int
  studentCount Int
  department   Department @relation(fields: [departmentId], references: [id])
}

model Classroom {
  id       String        @id @default(cuid())
  name     String
  capacity Int
  type     ClassroomType
  campusId String
  campus   Campus        @relation(fields: [campusId], references: [id])
  sessions Session[]

  @@unique([name, campusId])
}

model Schedule {
  id          String         @id @default(cuid())
  semester    String
  generatedBy String
  status      ScheduleStatus @default(DRAFT)
  createdAt   DateTime       @default(now())
  campusId    String?
  sessions    Session[]
  campus      Campus?        @relation(fields: [campusId], references: [id])
}

model Constraint {
  id          String         @id @default(cuid())
  name        String
  description String?
  type        ConstraintType
  value       String
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Session {
  id           String      @id @default(cuid())
  name         String
  type         SessionType @default(LECTURE)
  day          DayOfWeek?
  startTime    DateTime?
  endTime      DateTime?
  studentCount Int         @default(0)
  courseId     String
  instructorId String?
  classroomId  String?
  scheduleId   String?
  classroom    Classroom?  @relation(fields: [classroomId], references: [id])
  course       Course      @relation(fields: [courseId], references: [id])
  instructor   User?       @relation(fields: [instructorId], references: [id])
  schedule     Schedule?   @relation(fields: [scheduleId], references: [id])
}

enum DayOfWeek {
  SATURDAY
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
}

enum SessionType {
  LECTURE
  SECTION
}

enum CourseType {
  THEORETICAL
  PRACTICAL
}

enum ClassroomType {
  LECTURE_HALL
  LAB
}

enum UserRole {
  INSTRUCTOR
  ADMIN
  TA
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
}

enum AvailabilityStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReportStatus {
  UNREAD
  READ
}

enum ScheduleStatus {
  DRAFT
  PUBLISHED
}

enum ConstraintType {
  TIME
  CAPACITY
  INSTRUCTOR
  ROOM
  OTHER
}

generator erd {
  provider = "prisma-erd-generator"
}